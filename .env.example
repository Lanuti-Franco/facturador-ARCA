# Copia este archivo a .env y completa los valores. El .env NUNCA va a git.

# Token del bot (te lo da @BotFather en Telegram)
TELEGRAM_TOKEN=

# Tu chat_id numerico (mandale /id al bot para conocerlo).
# Es la allowlist: sin esto el bot NO arranca (fail-closed a proposito).
MI_CHAT_ID=

# Token de app.afipsdk.com (plan Free alcanza: 1 CUIT, 1k requests/mes)
AFIP_ACCESS_TOKEN=

# Supabase (Settings > API). Usar la key SECRETA (sb_secret_...),
# es server-side y saltea RLS: jamas exponerla en un cliente.
# OJO: la URL es https://<ref>.supabase.co, NO la del dashboard.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- Produccion ---
# false = modo test (CUIT de testing compartido del SDK, homologacion).
# true  = facturas REALES con tu CUIT/PV/certificado. Requiere las 4 de abajo.
PRODUCTION=false

# Tu CUIT sin guiones (solo produccion)
AFIP_CUIT=

# Tu punto de venta tipo Web Service (solo produccion)
AFIP_PUNTO_VENTA=

# Rutas al certificado y la private key de ARCA. Guardalos FUERA de la
# carpeta del repo (ej: ~/.arca-facturador/) con permisos 600.
AFIP_CERT_PATH=
AFIP_KEY_PATH=

# --- Datos del emisor para el PDF ---
# El nombre tiene que coincidir con el que figura en ARCA.
EMISOR_NOMBRE=
EMISOR_DOMICILIO=
EMISOR_INICIO_ACTIVIDADES=
# Texto de la linea de detalle del PDF (default: Servicios)
FACTURA_DESCRIPCION=Servicios
# Ruta a un logo (PNG o JPG) para el encabezado del PDF.
# Ideal apaisado (hasta ~200x56 se ve 1:1; mas grande se escala solo).
# Vacio = sin logo, el PDF sale como siempre.
LOGO_PATH=

# Tope anual de TU categoria de monotributo, en pesos sin puntos.
# Se actualiza cada semestre (ene/jul): actualizalo cuando cambie.
# Vacio = alerta de recategorizacion apagada.
MONOTRIBUTO_TOPE=

# --- Email al cliente (/mail) ---
# Con Gmail: SMTP_USER es tu mail (usuario@ejemplo.com) y SMTP_PASS una "contraseña de
# aplicacion" (myaccount.google.com/apppasswords), NO tu contraseña normal.
# Otro proveedor: agrega SMTP_HOST y SMTP_PORT (defaults: smtp.gmail.com:465).
# Vacio = /mail deshabilitado (todo lo demas funciona igual).
SMTP_USER=
SMTP_PASS=

# Umbral de identificacion del consumidor final, en pesos sin puntos.
# RG 5700/2025 (vigente jul-2026): 10000000. Igual o arriba de ese monto
# es OBLIGATORIO identificar al receptor (no se puede CF anonimo).
# Se actualiza por resolucion: verificalo. Vacio = alerta apagada.
UMBRAL_CF=10000000

# Que vendes: 1 = Productos, 2 = Servicios (default), 3 = ambos.
# Con productos (1) no hay periodo de servicio y la fecha retroactiva
# baja a 5 dias. La letra sigue siendo Factura C: esto es el campo
# Concepto del web service.
CONCEPTO=2
